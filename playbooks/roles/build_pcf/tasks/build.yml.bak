---
# =============================================================
# Build PCF — Compilation and Packaging
# =============================================================

- name: "[BUILD] Pre-build preparation"
  block:
    - name: "Remove old build directory"
      file:
        path: "{{ build_pcf_build_dir }}"
        state: absent

    - name: "Create build parent directory"
      file:
        path: "{{ build_pcf_build_dir | dirname }}"
        state: directory
        mode: '0755'

    - name: "Copy SVN repository to build directory"
      shell: |
        set -euo pipefail
        mkdir -p "{{ build_pcf_build_dir }}"
        cp -rv "{{ build_pcf_svn_repo }}"/* "{{ build_pcf_build_dir }}/"
        echo "✅ Repository copied to build directory"
      args:
        executable: /bin/bash
      changed_when: true

    - name: "Verify build directory populated"
      find:
        paths: "{{ build_pcf_build_dir }}"
        file_type: file
        recurse: yes
      register: build_files

    - name: "Fail if build directory is empty"
      fail:
        msg: |
          ❌ Build directory copy failed — no files found in {{ build_pcf_build_dir }}
      when: build_files.matched == 0

    - name: "Log build directory contents"
      debug:
        msg: "✅ Build directory populated with {{ build_files.matched }} files"

  rescue:
    - name: "Log build preparation failure"
      lineinfile:
        path: "{{ build_pcf_log }}"
        line: "[BUILD][PREP_FAILED] {{ ansible_failed_result.msg | default('Unknown error') }}"
        insertafter: EOF
      ignore_errors: yes

    - fail:
        msg: "Build preparation failed"

  tags:
    - build
    - build_prep

- name: "[BUILD] Compile PCF modules"
  block:
    - name: "Log build start"
      lineinfile:
        path: "{{ build_pcf_log }}"
        line: "[BUILD][START] {{ ansible_date_time.iso8601 }} — Building {{ build_pcf_branch }}"
        insertafter: EOF

    - name: "Capture build start timestamp"
      command: date +%s
      register: build_start_timestamp
      changed_when: false

    - name: "Run PCF build script"
      shell: |
        set -euo pipefail

        BUILD_SCRIPT="{{ build_pcf_build_dir }}/build.sh"
        
        # Verify build script exists
        if [ ! -f "$BUILD_SCRIPT" ]; then
          echo "❌ ERROR: Build script not found: $BUILD_SCRIPT"
          ls -la "{{ build_pcf_build_dir }}" | head -20
          exit 1
        fi

        echo "🔨 Starting PCF build..."
        echo "Build script: $BUILD_SCRIPT"
        echo "Branch     : {{ build_pcf_branch }}"
        echo "Build No   : {{ build_pcf_build_no }}"
        echo "Module Ver : {{ build_pcf_module_ver }}"
        echo "Start Time : {{ ansible_date_time.iso8601 }}"
        echo ""

        # Execute build script with proper error handling
        bash "$BUILD_SCRIPT" \
          --branch "{{ build_pcf_branch }}" \
          --build-no "{{ build_pcf_build_no }}" \
          --module-ver "{{ build_pcf_module_ver }}" \
          --output-dir "{{ build_pcf_build_dir }}" \
          2>&1 || BUILD_EXIT=$?

        if [ "${BUILD_EXIT:-0}" -ne 0 ]; then
          echo "❌ Build script exited with code ${BUILD_EXIT:-0}"
          exit ${BUILD_EXIT:-1}
        fi

        echo "✅ Build script completed successfully"
      args:
        executable: /bin/bash
        chdir: "{{ build_pcf_build_dir }}"
      register: build_result
      failed_when: build_result.rc != 0
      timeout: "{{ pcf.build_timeout_seconds | default(10800) }}"

    - name: "Display build output"
      debug:
        msg: |
          Build Output:
          {{ build_result.stdout_lines | default([]) | join('\n') }}

    - name: "Log build completion"
      lineinfile:
        path: "{{ build_pcf_log }}"
        line: "[BUILD][OUTPUT] {{ item }}"
        insertafter: EOF
      loop: "{{ build_result.stdout_lines | default([]) | slice(5) | list }}"

  rescue:
    - name: "Capture build failure details"
      shell: |
        echo "=== BUILD FAILURE DEBUG INFO ==="
        echo "Build directory: {{ build_pcf_build_dir }}"
        echo ""
        echo "=== Directory contents ==="
        ls -ltra "{{ build_pcf_build_dir }}" 2>/dev/null | tail -20 || echo "Cannot list directory"
        echo ""
        echo "=== Build script check ==="
        if [ -f "{{ build_pcf_build_dir }}/build.sh" ]; then
          head -20 "{{ build_pcf_build_dir }}/build.sh"
        else
          echo "build.sh not found"
        fi
      register: build_debug
      ignore_errors: yes

    - name: "Log build failure details"
      lineinfile:
        path: "{{ build_pcf_log }}"
        line: "[BUILD][FAILED] {{ ansible_failed_result.msg | default('Unknown error') }} — {{ ansible_date_time.iso8601 }}"
        insertafter: EOF
      ignore_errors: yes

    - debug:
        msg: "{{ build_debug.stdout_lines | default([]) }}"

    - fail:
        msg: |
          ❌ PCF build failed for {{ build_pcf_branch }}
          Build Dir: {{ build_pcf_build_dir }}
          See {{ build_pcf_log }} for details

  tags:
    - build
    - build_compile

- name: "[BUILD] Locate and validate generated RPM"
  block:
    - name: "Search for generated PCF RPM"
      find:
        paths: "{{ build_pcf_build_dir }}"
        patterns: "pcf-module-*.rpm"
        recurse: yes
        file_type: file
      register: generated_rpms

    - name: "Verify RPM was generated"
      fail:
        msg: |
          ❌ No PCF RPM generated for {{ build_pcf_branch }}
          Searched: {{ build_pcf_build_dir }}
          Expected pattern: pcf-module-*.rpm
          
          Debug info:
          {{ build_debug.stdout_lines | default([]) | join('\n') }}
      when: generated_rpms.matched == 0

    - name: "Use most recent RPM if multiple exist"
      set_fact:
        build_pcf_rpm_path: "{{ generated_rpms.files | sort(attribute='mtime', reverse=true) | first }}"

    - name: "Display found RPM"
      debug:
        msg: |
          ✅ PCF RPM located:
          Path: {{ build_pcf_rpm_path.path }}
          Size: {{ build_pcf_rpm_path.size }} bytes
          Modified: {{ build_pcf_rpm_path.mtime | int | timestamp_to_date }}

    - name: "Verify RPM file is valid"
      shell: |
        set -euo pipefail
        RPM_FILE="{{ build_pcf_rpm_path.path }}"
        
        # Check file exists and is readable
        if [ ! -r "$RPM_FILE" ]; then
          echo "❌ RPM file not readable: $RPM_FILE"
          exit 1
        fi
        
        # Verify RPM magic bytes (ED AB EE DB)
        MAGIC=$(xxd -p -l 4 "$RPM_FILE")
        if [ "$MAGIC" != "edabeedd" ] && [ "$MAGIC" != "edabeedb" ]; then
          echo "❌ Not a valid RPM file (wrong magic bytes)"
          exit 1
        fi
        
        echo "✅ RPM file structure is valid"
      args:
        executable: /bin/bash
      register: rpm_validation

    - name: "Query RPM metadata"
      shell: |
        set -euo pipefail
        rpm -qp \
          --queryformat "NAME=%{NAME}\nVERSION=%{VERSION}\nRELEASE=%{RELEASE}\nARCH=%{ARCH}\n" \
          "{{ build_pcf_rpm_path.path }}"
      args:
        executable: /bin/bash
      register: rpm_metadata

    - name: "Parse RPM metadata"
      set_fact:
        rpm_name: "{{ (rpm_metadata.stdout_lines | select('match', '^NAME=') | first | split('='))[1] }}"
        rpm_version: "{{ (rpm_metadata.stdout_lines | select('match', '^VERSION=') | first | split('='))[1] }}"
        rpm_release: "{{ (rpm_metadata.stdout_lines | select('match', '^RELEASE=') | first | split('='))[1] }}"
        rpm_arch: "{{ (rpm_metadata.stdout_lines | select('match', '^ARCH=') | first | split('='))[1] }}"

    - name: "Display RPM metadata"
      debug:
        msg: |
          📦 RPM Metadata:
          ├─ Name    : {{ rpm_name }}
          ├─ Version : {{ rpm_version }}
          ├─ Release : {{ rpm_release }}
          └─ Arch    : {{ rpm_arch }}

    - name: "Validate RPM version matches branch"
      assert:
        that:
          - rpm_version == build_pcf_version
        fail_msg: |
          ❌ RPM version mismatch
          Expected : {{ build_pcf_version }}
          Got      : {{ rpm_version }}
        success_msg: "✅ RPM version matches branch: {{ rpm_version }}"

    - name: "Generate RPM checksum"
      shell: |
        md5sum "{{ build_pcf_rpm_path.path }}" | awk '{print $1}'
      register: rpm_checksum
      changed_when: false

    - name: "Log RPM details"
      copy:
        content: |
          ============================================================
          PCF BUILD RPM MANIFEST
          ============================================================
          Build Branch    : {{ build_pcf_branch }}
          Build Number    : {{ build_pcf_build_no }}
          Module Version  : {{ build_pcf_module_ver }}
          
          RPM Details:
          Path            : {{ build_pcf_rpm_path.path }}
          Filename        : {{ build_pcf_rpm_path.path | basename }}
          Size            : {{ build_pcf_rpm_path.size }} bytes
          MD5 Checksum    : {{ rpm_checksum.stdout }}
          
          RPM Metadata:
          Name            : {{ rpm_name }}
          Version         : {{ rpm_version }}
          Release         : {{ rpm_release }}
          Architecture    : {{ rpm_arch }}
          
          Build Timestamp : {{ ansible_date_time.iso8601 }}
          Build Host      : {{ inventory_hostname }}
          ============================================================
        dest: "{{ build_pcf_releases_dir }}/BUILD_MANIFEST_{{ build_pcf_build_no }}.txt"
        mode: '0644'

    - name: "Copy RPM to releases directory"
      copy:
        src: "{{ build_pcf_rpm_path.path }}"
        dest: "{{ build_pcf_releases_dir }}/{{ build_pcf_rpm_path.path | basename }}"
        remote_src: yes
        mode: '0644'
      register: rpm_copy

    - name: "Log final RPM location"
      lineinfile:
        path: "{{ build_pcf_log }}"
        line: |
          [BUILD][SUCCESS] RPM generated and copied
          File: {{ build_pcf_releases_dir }}/{{ build_pcf_rpm_path.path | basename }}
          Checksum: {{ rpm_checksum.stdout }}
          Timestamp: {{ ansible_date_time.iso8601 }}
        insertafter: EOF

  rescue:
    - name: "Log RPM validation failure"
      lineinfile:
        path: "{{ build_pcf_log }}"
        line: "[BUILD][RPM_VALIDATION_FAILED] {{ ansible_failed_result.msg | default('Unknown error') }}"
        insertafter: EOF
      ignore_errors: yes

    - fail:
        msg: "RPM validation failed — see {{ build_pcf_log }} for details"

  tags:
    - build
    - build_rpm_validate